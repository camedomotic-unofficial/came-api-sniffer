{
  "name": "CAME API Sniffer",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [80, 8081],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylint",
        "charliermarsh.ruff"
      ]
    }
  },
  "postCreateCommand": "pip install -r requirements.txt",
  "runArgs": ["--network=host"]
}
